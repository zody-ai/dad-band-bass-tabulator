{
  "name": "basstab",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "build": "expo export --platform web",
    "start": "npx serve dist -s -l tcp://0.0.0.0:${PORT:-3000}",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "export:web": "expo export --platform web",
    "verify:linux": "npm run typecheck && npm run export:web",
    "test:note-style": "node -r ts-node/register tests/noteRenderStyle.test.ts",
    "test:auth": "node -r ts-node/register tests/authFlow.test.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.8",
    "@react-navigation/native": "^7.2.1",
    "@react-navigation/native-stack": "^7.14.9",
    "expo": "~55.0.8",
    "expo-file-system": "~55.0.12",
    "expo-linking": "~55.0.14",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@types/node": "^22.5.2",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.12",
    "dotenv": "^17.4.1",
    "ts-node": "^10.9.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
